[app]
title = 好返助手
package.name = haofanhelper
package.domain = org.haofan
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 1.0
requirements = python3,pywebview,flask,aiohttp,requests,urllib3,pyjnius
orientation = portrait
osx.python_version = 3
osx.kivy_version = 2.1.0
fullscreen = 0
android.api = 33
android.ndk = 25b
android.sdk = 24
android.buildtools = 33.0.0
android.arch = arm64-v8a
android.apptheme = @android:style/Theme.Material.Light.NoActionBar
android.add_assets = .
android.permissions = INTERNET,ACCESS_NETWORK_STATE,ACCESS_WIFI_STATE
android.entrypoint = org.kivy.android.PythonActivity
android.launcher = org.kivy.android.PythonLauncher
android.service.autostart = True
android.service.name = haofan_helper
android.service.entrypoint = org.kivy.android.PythonService
p4a.source_dir = .
p4a.bootstrap = webview
p4a.local_recipes =
p4a.libSDL2_ttf = True